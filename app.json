{
  "expo": {
    "name": "EduManager",
    "slug": "gestao-escolar",
    "scheme": "gestao-escolar",
    "version": "1.0.0",

    "sdkVersion": "55.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"

    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.gestaoescolar"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"

      },
      "package": "com.anonymous.gestaoescolar"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "2.1.20",

            "jdkVersion": 17
          }
        }
      ]
    ],


    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "83cf70fd-652e-424f-a9f2-35a9a15ccb9e"
      }
    }
  }
}
